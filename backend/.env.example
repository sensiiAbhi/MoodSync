# MoodSync Backend Environment Variables
# Copy this to .env and fill in real values

# ── App ──
APP_NAME=MoodSync
APP_ENV=development
DEBUG=true

# ── Security (CHANGE IN PRODUCTION!) ──
SECRET_KEY=your-super-secret-key-minimum-32-characters-long-change-me

# ── Database ──
DATABASE_URL=postgresql+asyncpg://moodsync_user:moodsync_secret@localhost:5432/moodsync

# ── Spotify API (Get from https://developer.spotify.com/dashboard) ──
# Leave empty to use mock data (works without Spotify)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── CORS ──
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Redis (optional) ──
REDIS_URL=redis://localhost:6379/0

# ── Token Expiry ──
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
